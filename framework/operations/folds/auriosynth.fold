# fold_responsibility

maintains: framework/operations/folds/auriosynth.fold
also reads: firmament/space/auriosynth.fold (space-level state)
writes: implementation log (append-only)

# connections

bonds:
  - guild: "coordinates system builds — AurioSynth directs, Guild executes"
  - constellary: "reports system state to main session when asked"
  - all_entities: "reads all folds — the connective fabric knows everything"
  - auriosynth.csmcl: "cross-plane fabric link via Rainbow Path (when connected)"

reads: [framework/operations/folds/, framework/operations/familiars/,
        framework/standards/, framework/bootstrap/,
        firmament/space/auriosynth.fold]
writes: [framework/operations/folds/auriosynth.fold]

