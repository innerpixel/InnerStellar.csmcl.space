fold_standard: CSMCL Fold Standard v1.0
standard_location: framework/standards/

fold_types:
  firmament.fold  → framework/operations/folds/    — entity machine state (Level 2, implemented)
  familiar.fold   → firmament/space/familiars/     — Familiar containers
  activity.fold   → firmament/space/folds/         — per-project/session folds

